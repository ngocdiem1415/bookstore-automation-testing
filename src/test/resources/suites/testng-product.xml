<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Product Suite" verbose="1">
    <parameter name="appURL" value="http://localhost:8080" />
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener" />
    </listeners>

    <test name="Product - Detail">
        <classes>
            <class name="com.bookstore.tests.product.ProductDetailTest" >
                <methods>
                    <include name="PROD_DET_01_ValidProductDetail"/>
                    <include name="PROD_DET_02_HiddenProductReturns404"/>
                    <include name="PROD_DET_03_SqlInjectionIdBoundary"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Product - Filter">
        <classes>
            <class name="com.bookstore.tests.product.ProductFilterTest" >
                <methods>
                    <include name="PROD_FIL_01_FilterByValidPriceRange"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Product - Sort">
        <classes>
            <class name="com.bookstore.tests.product.ProductSortTest" >
                <methods>
                    <include name="PROD_FIL_01_SortByPriceAscending"/>
                    <include name="PROD_FIL_02_SortByPriceDescending"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Product - Navigate">
        <classes>
            <class name="com.bookstore.tests.product.ProductNavigateTest" >
                <methods>
                    <include name="PROD_NAV_01_ValidCategoryShowsBooks"/>
                    <include name="PROD_NAV_02_SwitchCategoryUpdatesProductList"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
