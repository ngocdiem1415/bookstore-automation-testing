<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Cart Suite" verbose="1">
    <parameter name="appURL" value="http://localhost:8080"/>
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener"/>
    </listeners>

    <test name="Cart - Add Items">
        <classes>
            <class name="com.bookstore.tests.cart.CartAddTest">
                <methods>
                    <include name="CART_ADD_01_AddInStockProduct"/>
                    <include name="CART_ADD_02_OutOfStockButtonDisabled"/>
                    <include name="CART_ADD_03_ExceedStockQuantityBoundary"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Cart - Update Quantity">
        <classes>
            <class name="com.bookstore.tests.cart.CartUpdateTest">
                <methods>
                    <include name="CART_UPD_01_IncreaseQuantity"/>
                    <include name="CART_UPD_02_CannotTypeNegativeQuantity"/>
                    <include name="CART_UPD_03_DecreaseQuantityAtMinimum"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Cart - Delete Items">
        <classes>
            <class name="com.bookstore.tests.cart.CartDeleteTest">
                <methods>
                    <include name="CART_DEL_01_DeleteOneItem"/>
                    <include name="CART_DEL_02_DeleteAllItemsIndividually"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
