<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Order Module Suite" verbose="1">
<!--    <parameter name="appURL" value="http://localhost:8080" />-->
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener" />
    </listeners>

    <!-- ORDER LISTING -->
    <test name="Order - History List">
        <classes>
            <class name="com.bookstore.tests.order.OrderListTest">
                <methods>
                    <include name="ORD_LST_01_ViewOrderHistory"/>
                    <include name="ORD_LST_02_NewUserEmptyOrderHistory"/>
                    <include name="ORD_LST_03_SearchOrderByProductName"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ORDER DETAIL -->
    <test name="Order - Details View">
        <classes>
            <class name="com.bookstore.tests.order.OrderDetailTest">
                <methods>
                    <include name="ORD_DET_01_ViewOrderDetail"/>
                    <include name="ORD_DET_02_InvalidOrderId"/>
                    <include name="ORD_DET_03_IdorBoundary"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ORDER CANCELLATION -->
    <test name="Order - Cancellation">
        <classes>
            <class name="com.bookstore.tests.order.OrderCancelTest">
                <methods>
                    <include name="ORD_CAN_01_CancelPendingOrder"/>
                    <include name="ORD_CAN_02_CannotCancelShippedOrder"/>
                    <include name="ORD_CAN_03_StockRestoredOnCancel"/>
                </methods>
            </class>
        </classes>
    </test>

