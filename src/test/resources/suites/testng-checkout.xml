<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Checkout Suite" verbose="1">
<!--    <parameter name="appURL" value="http://localhost:8080" />-->
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener" />
    </listeners>

    <!-- SHIPPING INFO -->
    <test name="Checkout - Shipping Information">
        <classes>
            <class name="com.bookstore.tests.checkout.CheckoutInfoTest">
                <methods>
                    <include name="CHECKOUT_INFO_01_FillShippingInfoSuccess"/>
                    <include name="CHECKOUT_INFO_02_EmptyWardBlocked"/>
                    <include name="CHECKOUT_INFO_03_XssAddressBoundary"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- COD PAYMENT -->
    <test name="Checkout - COD Payment">
        <classes>
            <class name="com.bookstore.tests.checkout.CheckoutCodTest" >
                <methods>
                    <include name="CHECKOUT_COD_01_PlaceOrderCod"/>
                    <include name="CHECKOUT_COD_02_EmptyCartBoundary"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- VNPAY PAYMENT -->
    <test name="Checkout - VNPay Payment">
        <classes>
            <class name="com.bookstore.tests.checkout.CheckoutVnpayTest">
                <methods>
                    <include name="CHECKOUT_VNP_01_VnpayPaymentSuccess"/>
                    <include name="CHECKOUT_VNP_02_VnpayRedirect"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
