<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Admin Suite" verbose="1">
    <!--    <parameter name="appURL" value="http://localhost:8080" />-->
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener"/>
    </listeners>
    <test name="Admin - Authentication">
        <classes>
            <class name="com.bookstore.tests.admin.AdminAuthTest">
                <methods>
                    <include name="ADM_AUT_01_AdminLoginDashboard"/>
                    <include name="ADM_AUT_02_NormalUserCannotAccessAdmin"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Admin - Category">
        <classes>
            <class name="com.bookstore.tests.admin.AdminCategoryTest">
                <methods>
                    <include name="ADM_CAT_01_AddCategorySuccess"/>
                    <include name="ADM_CAT_02_DuplicateCategoryName"/>
                    <include name="ADM_CAT_03_LongNameBoundary"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Admin - Order Management">
        <classes>
            <class name="com.bookstore.tests.admin.AdminOrderTest">
                <methods>
                    <include name="ADM_ORD_01_CompleteShippingOrder"/>
                    <include name="ADM_ORD_02_UpdateStatusBackward"/>
                    <include name="ADM_ORD_03_CancelPendingOrder"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Admin - Product Management">
        <classes>
            <class name="com.bookstore.tests.admin.AdminProductTest">
                <methods>
                    <include name="ADM_PRD_01_AddProductSuccess"/>
                    <include name="ADM_PRD_02_AddProductNegativePrice"/>
                    <include name="ADM_PRD_03_UploadExecutableFileBoundary"/>
                    <include name="ADM_PRD_04_EditProductSuccess"/>
                    <include name="ADM_PRD_05_EditProductBlankTitle"/>
                    <include name="ADM_PRD_06_DeleteUnusedProduct"/>
                    <include name="ADM_PRD_07_CancelDeleteProduct"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Admin - User Management">
        <classes>
            <class name="com.bookstore.tests.admin.AdminUserTest">
                <methods>
                    <include name="ADM_USR_01_AdminBlocksUser"/>
                    <include name="ADM_USR_02_BlockedUserCannotLogin"/>
                    <include name="ADM_USR_03_AdminSelfBlockBoundary"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
