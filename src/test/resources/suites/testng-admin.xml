<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Suite: Admin Module | mvn test -Dsurefire.suiteXmlFiles=testng-admin.xml -->
<suite name="Admin Suite" verbose="1">
    <parameter name="appURL" value="http://localhost:8080" />
    <listeners>
        <listener class-name="com.bookstore.listeners.TestListener" />
    </listeners>
    <test name="Admin - Authentication">
        <classes><class name="com.bookstore.tests.admin.AdminAuthTest" /></classes>
    </test>
    <test name="Admin - Product (Add/Edit/Delete)">
        <classes><class name="com.bookstore.tests.admin.AdminProductTest" /></classes>
    </test>
    <test name="Admin - Category">
        <classes><class name="com.bookstore.tests.admin.AdminCategoryTest" /></classes>
    </test>
    <test name="Admin - Order Management">
        <classes><class name="com.bookstore.tests.admin.AdminOrderTest" /></classes>
    </test>
    <test name="Admin - User Management">
        <classes><class name="com.bookstore.tests.admin.AdminUserTest" /></classes>
    </test>
</suite>
