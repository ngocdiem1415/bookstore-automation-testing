<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Debug Login Suite" verbose="1">
    <test name="Login Debug Task">
        <classes>
            <class name="com.bookstore.tests.RegisterTest">
                <methods>
                    <include name="AUTH_LOG_01_LoginSuccessCustomer" />
                    <include name="AUTH_LOG_02_LoginSuccessAdmin"/>
                    <include name="AUTH_LOG_03_LoginSuccessOrderStaff"/>
                    <include name="AUTH_LOG_04_LoginFailInvalidPassword"/>
                    <include name="AUTH_LOG_05_LoginFailSQLInjection"/>
                    <include name="AUTH_OUT_01_LogoutSuccess"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>